{
  "name": "predictix-backend",
  "version": "1.0.0",
  "description": "API server for Predictix sports betting tracker",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ignore": [
      "predictix.db*",
      "*.db*",
      "*.db-journal",
      "*.db-wal",
      "*.db-shm"
    ]
  }
}
